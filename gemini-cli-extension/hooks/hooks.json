{
  "hooks": {
    "AfterTool": [
      {
        "matcher": "^(gemini_(ready|tabs|chats|export|job|config|support)|mcp_+gemini[-_]md[-_]export_+gemini[-_](ready|tabs|chats|export|job|config|support))$",
        "hooks": [
          {
            "name": "gemini-md-export-media-audit",
            "description": "Warn the agent when exported media needs follow-up.",
            "type": "command",
            "command": "node \"${extensionPath}${/}scripts${/}hooks${/}gemini-md-export-hook.mjs\" after-tool",
            "timeout": 3000
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "^(gemini_(ready|tabs|chats|export|job|config|support)|mcp_+gemini[-_]md[-_]export_+gemini[-_](ready|tabs|chats|export|job|config|support))$",
        "hooks": [
          {
            "name": "gemini-md-export-browser-ready",
            "description": "Open and wait for Gemini web before exporter tools run.",
            "type": "command",
            "command": "node \"${extensionPath}${/}scripts${/}hooks${/}gemini-md-export-hook.mjs\" before-tool",
            "timeout": 20000
          }
        ]
      },
      {
        "matcher": "^(write_file|replace|run_shell_command|shell|edit|apply_patch)$",
        "hooks": [
          {
            "name": "gemini-md-export-scope-guard",
            "description": "Block forbidden Gemini scraping and media fallback implementation paths.",
            "type": "command",
            "command": "node \"${extensionPath}${/}scripts${/}hooks${/}gemini-md-export-hook.mjs\" before-tool",
            "timeout": 3000
          }
        ]
      }
    ]
  }
}
